# Database — gebruik een PostgreSQL URL (bijv. Supabase connection string)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT
SECRET_KEY=vervang-dit-met-een-lange-willekeurige-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Anthropic API (voor AI recipe scraper)
ANTHROPIC_API_KEY=sk-ant-...

# CORS — frontend URL(s), kommagescheiden
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
